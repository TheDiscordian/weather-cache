# weather-cache configuration
# Copy this file to ~/.config/weather-cache/weather-cache.conf and edit it.

# Required: your location coordinates (used by Open-Meteo)
LATITUDE="43.65"
LONGITUDE="-79.38"

# Required: location name (used by wttr.in fallback)
LOCATION_NAME="Toronto Ontario"

# Optional: units — "metric" (°C, km/h) or "imperial" (°F, mph). Default: metric
# UNITS="imperial"

# Optional: timezone (auto-detected from /etc/timezone if not set)
# TIMEZONE="America/Toronto"

# Optional: cache directory (default: ~/.cache/weather)
# CACHE_DIR="$HOME/.cache/weather"

# Optional: Environment Canada alerts bounding box (lon_min,lat_min,lon_max,lat_max)
# Only needed if you want weather alerts (Canada only).
# To create a bounding box, take your coordinates and offset by ~0.2-0.3 degrees:
#   lon_min = LONGITUDE - 0.2
#   lat_min = LATITUDE  - 0.15
#   lon_max = LONGITUDE + 0.2
#   lat_max = LATITUDE  + 0.15
# Example for Toronto (43.65, -79.38): "-79.6,43.5,-79.2,43.8"
# ALERT_BBOX="-79.6,43.5,-79.2,43.8"

# Optional: filter alerts by area name (defaults to LOCATION_NAME)
# ALERT_FILTER="Toronto"
